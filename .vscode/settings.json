{
    "files.autoSave": "onFocusChange",
    "files.associations": {
        "LICENSE-APACHE": "plaintext",
        "LICENSE-MIT": "plaintext"
    },
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "[markdown]": {
        "editor.formatOnSave": true,
        "editor.formatOnPaste": true
    },
    "cSpell.customDictionaries": {
        "cSpell-dictionary": {
            "name": "cSpell-dictionary",
            "path": "${workspaceRoot}/.vscode/cSpell-dictionary.txt",
            "description": "project's cSpell Dictionary",
            "addWords": true
        },
        "custom": true,
        "internal-terms": false
    },
    "cSpell.ignorePaths": [
        ".git",
        ".gitignore",
        ".vscode"
    ]
}
